<%- include('../partials/public-header', { title }) %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-sm border-0 mobile-card">
      <div class="card-body p-4">
        <div class="text-center mb-4">
          <h3 class="mb-1">Setup Admin Awal</h3>
          <p class="text-muted mb-0">Buat akun admin pertama langsung ke database.</p>
        </div>
        <form action="/setup" method="post">
          <div class="form-group">
            <label>Username Admin</label>
            <input type="text" name="username" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Konfirmasi Password</label>
            <input type="password" name="confirm_password" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-primary btn-block">Buat Admin</button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/public-footer') %>
