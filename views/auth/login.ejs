<%- include('../partials/public-header', { title, showFlash: false }) %>

<div class="row justify-content-center">
  <div class="col-md-5 col-lg-4">
    <div class="card shadow-sm border-0 mobile-card">
      <div class="card-body p-4">
        <% if (flash) { %>
          <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
        <% } %>
        <div class="text-center mb-4">
          <% if (appConfig?.logo_url) { %>
            <div class="mb-3">
              <img src="<%= appConfig.logo_url %>" alt="Logo" class="auth-logo">
            </div>
          <% } %>
          <h3 class="mb-1">PAMSIMAS</h3>
          <p class="text-muted mb-0">Login Admin / Catter / Pelanggan</p>
        </div>
        <form action="/login" method="post">
          <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" class="form-control" required>
          </div>
          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-primary btn-block">Masuk</button>
        </form>
        <div class="text-center mt-3">
          <a href="/pelanggan/cek" class="text-decoration-none">Cek tagihan tanpa login</a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/public-footer') %>
