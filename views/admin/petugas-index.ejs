<%- include('../partials/admin-header', { title, activeMenu: 'petugas' }) %>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="card-title mb-0">Daftar Petugas</h3>
    <a href="/admin/petugas/new" class="btn btn-primary btn-sm">Tambah Petugas</a>
  </div>
  <div class="card-body table-responsive p-0">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Username</th>
          <th>Role</th>
          <th>Dibuat</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% petugas.forEach((item) => { %>
          <tr>
            <td><%= item.username %></td>
            <td><span class="badge badge-<%= item.role === 'kasir' ? 'success' : 'info' %>"><%= item.role %></span></td>
            <td><%= helpers.formatDate(item.created_at) %></td>
            <td class="text-nowrap">
              <a href="/admin/petugas/<%= item.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
              <form action="/admin/petugas/<%= item.id %>/delete" method="post" class="d-inline">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Hapus petugas ini?')">Hapus</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/admin-footer') %>
