<%- include('../partials/admin-header', { title, activeMenu: 'dashboard' }) %>

<div class="row">
  <div class="col-lg-3 col-6">
    <div class="small-box bg-info">
      <div class="inner">
        <h3><%= analytics.summary.total_pelanggan %></h3>
        <p>Total Pelanggan</p>
      </div>
      <div class="icon"><i class="fas fa-users"></i></div>
    </div>
  </div>
  <div class="col-lg-3 col-6">
    <div class="small-box bg-warning">
      <div class="inner">
        <h3><%= analytics.summary.tagihan_belum_lunas %></h3>
        <p>Belum Lunas</p>
      </div>
      <div class="icon"><i class="fas fa-file-invoice"></i></div>
    </div>
  </div>
  <div class="col-lg-3 col-6">
    <div class="small-box bg-success">
      <div class="inner">
        <h3><%= helpers.formatCurrency(analytics.summary.total_pemasukan) %></h3>
        <p>Total Pemasukan</p>
      </div>
      <div class="icon"><i class="fas fa-wallet"></i></div>
    </div>
  </div>
  <div class="col-lg-3 col-6">
    <div class="small-box bg-danger">
      <div class="inner">
        <h3><%= helpers.formatCurrency(analytics.summary.total_pengeluaran) %></h3>
        <p>Total Pengeluaran</p>
      </div>
      <div class="icon"><i class="fas fa-tools"></i></div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-6">
    <div class="card card-primary">
      <div class="card-header"><h3 class="card-title">Alur Tagihan Otomatis</h3></div>
      <div class="card-body">
        <p class="mb-2">
          Catter input meter pada tanggal
          <strong><%= collectionWindow.startDay %> - <%= collectionWindow.endDay %></strong>.
          Data pemakaian periode tersebut akan dipakai untuk tagihan bulan berikutnya.
        </p>
        <p class="mb-2">
          Generate otomatis mulai tanggal
          <strong><%= autoGenerateDay %></strong>
          setiap awal periode tagihan.
        </p>
        <div class="alert alert-light border mb-0">
          <div><strong>Pencatatan default:</strong> <%= generationDefaults.sourcePeriod.bulan %>/<%= generationDefaults.sourcePeriod.tahun %></div>
          <div><strong>Tagihan default:</strong> <%= generationDefaults.billingPeriod.bulan %>/<%= generationDefaults.billingPeriod.tahun %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card card-success">
      <div class="card-header"><h3 class="card-title">Generate Tagihan Manual</h3></div>
      <div class="card-body">
        <form action="/admin/tagihan/generate" method="post">
          <input type="hidden" name="redirect_to" value="/admin">
          <div class="form-row">
            <div class="form-group col-md-6">
              <label>Bulan Pencatatan</label>
              <input type="number" name="source_month" class="form-control" min="1" max="12" value="<%= generationDefaults.sourcePeriod.bulan %>" required>
            </div>
            <div class="form-group col-md-6">
              <label>Tahun Pencatatan</label>
              <input type="number" name="source_year" class="form-control" min="2000" max="3000" value="<%= generationDefaults.sourcePeriod.tahun %>" required>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group col-md-6">
              <label>Bulan Tagihan</label>
              <input type="number" name="billing_month" class="form-control" min="1" max="12" value="<%= generationDefaults.billingPeriod.bulan %>" required>
            </div>
            <div class="form-group col-md-6">
              <label>Tahun Tagihan</label>
              <input type="number" name="billing_year" class="form-control" min="2000" max="3000" value="<%= generationDefaults.billingPeriod.tahun %>" required>
            </div>
          </div>
          <p class="text-muted mb-3">Dipakai jika perlu generate ulang atau percepatan tanpa menunggu jadwal otomatis.</p>
          <button type="submit" class="btn btn-success">Generate Sekarang</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="card card-info card-outline">
      <div class="card-header">
        <h3 class="card-title"><i class="fas fa-file-export mr-2"></i>Unduh Laporan Keuangan & Pemakaian (CSV)</h3>
      </div>
      <div class="card-body">
        <form action="/admin/laporan/export-csv" method="get">
          <div class="row align-items-end">
            <div class="col-md-3 form-group">
              <label>Jenis Laporan</label>
              <select name="jenis" id="export-jenis" class="form-control" required>
                <option value="bku">Buku Kas Umum (Pemasukan/Pengeluaran)</option>
                <option value="rekap_pemakaian">Rekap Pemakaian Air Pelanggan</option>
                <option value="tunggakan">Daftar Tunggakan Tagihan</option>
              </select>
            </div>
            
            <div class="col-md-3 form-group filter-tanggal">
              <label>Dari Tanggal</label>
              <input type="date" name="dari" class="form-control" id="export-dari">
            </div>
            <div class="col-md-3 form-group filter-tanggal">
              <label>Sampai Tanggal</label>
              <input type="date" name="sampai" class="form-control" id="export-sampai">
            </div>

            <div class="col-md-3 form-group filter-periode" style="display: none;">
              <label>Bulan</label>
              <select name="bulan" class="form-control">
                <% for(let m=1; m<=12; m++) { %>
                  <option value="<%= m %>" <%= m === (new Date().getMonth() + 1) ? 'selected' : '' %>><%= m %></option>
                <% } %>
              </select>
            </div>
            <div class="col-md-3 form-group filter-periode" style="display: none;">
              <label>Tahun</label>
              <input type="number" name="tahun" class="form-control" value="<%= new Date().getFullYear() %>" min="2000" max="3000">
            </div>

            <div class="col-md-3 form-group">
              <button type="submit" class="btn btn-info btn-block font-weight-bold">
                <i class="fas fa-download mr-1"></i> Unduh File CSV
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const exportJenis = document.getElementById('export-jenis');
    if (exportJenis) {
      const filterTanggal = document.querySelectorAll('.filter-tanggal');
      const filterPeriode = document.querySelectorAll('.filter-periode');
      
      const now = new Date();
      const firstDay = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
      const lastDay = new Date(now.getFullYear(), now.getMonth() + 1, 0).toISOString().split('T')[0];
      
      document.getElementById('export-dari').value = firstDay;
      document.getElementById('export-sampai').value = lastDay;

      exportJenis.addEventListener('change', function () {
        if (this.value === 'bku') {
          filterTanggal.forEach(el => el.style.display = 'block');
          filterPeriode.forEach(el => el.style.display = 'none');
        } else {
          filterTanggal.forEach(el => el.style.display = 'none');
          filterPeriode.forEach(el => el.style.display = 'block');
        }
      });
    }
  });
</script>

<div class="row">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header"><h3 class="card-title">Grafik Keuangan Bulanan</h3></div>
      <div class="card-body"><canvas id="financeChart" height="140"></canvas></div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header"><h3 class="card-title">Status Pembayaran</h3></div>
      <div class="card-body"><canvas id="paymentChart" height="220"></canvas></div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-title">Kubik Air Terjual</h3></div>
      <div class="card-body"><canvas id="cubicChart" height="160"></canvas></div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header"><h3 class="card-title">Tagihan Terbaru</h3></div>
      <div class="card-body table-responsive p-0">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Pelanggan</th>
              <th>Periode</th>
              <th>Total</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentBills.length) { %>
              <% recentBills.forEach((item) => { %>
                <tr>
                  <td><%= item.nama %><br><small class="text-muted"><%= item.no_meteran %></small></td>
                  <td>
                    <div><strong><%= item.bulan %>/<%= item.tahun %></strong></div>
                    <small class="text-muted">Baca <%= item.bulan_baca %>/<%= item.tahun_baca %></small>
                  </td>
                  <td><%= helpers.formatCurrency(item.total_tagihan) %></td>
                  <td>
                    <span class="badge badge-<%= item.status_bayar === 'lunas' ? 'success' : 'warning' %>">
                      <%= item.status_bayar %>
                    </span>
                    <span class="badge badge-<%= item.generated_mode === 'auto' ? 'primary' : 'secondary' %>">
                      <%= item.generated_mode %>
                    </span>
                    <% if (item.qris_amount_unique) { %>
                      <div><small class="text-muted">QRIS <%= helpers.formatCurrency(item.qris_amount_unique) %> / kode <%= String(item.qris_unique_code || 0).padStart(3, '0') %></small></div>
                    <% } %>
                  </td>
                  <td>
                    <% if (item.status_bayar !== 'lunas') { %>
                      <div class="d-flex flex-wrap" style="gap:6px;">
                        <form action="/admin/tagihan/<%= item.id %>/lunas" method="post" class="form-inline">
                          <input type="hidden" name="metode_bayar" value="tunai">
                          <button class="btn btn-sm btn-success" type="submit">Lunaskan</button>
                        </form>
                        <form action="/admin/tagihan/<%= item.id %>/qris-assign" method="post" class="form-inline">
                          <button class="btn btn-sm btn-primary" type="submit"><%= item.qris_amount_unique ? 'QRIS Ulang' : 'QRIS' %></button>
                        </form>
                        <% if (item.qris_amount_unique) { %>
                          <form action="/admin/tagihan/<%= item.id %>/qris-assign?force=1" method="post" class="form-inline">
                            <button class="btn btn-sm btn-warning" type="submit">Regenerate</button>
                          </form>
                          <form action="/admin/tagihan/<%= item.id %>/qris-clear" method="post" class="form-inline">
                            <button class="btn btn-sm btn-outline-danger" type="submit">Clear</button>
                          </form>
                        <% } %>
                        <form action="/admin/tagihan/<%= item.id %>/wa-qris" method="post" class="form-inline">
                          <button class="btn btn-sm btn-success" type="submit">Kirim WA</button>
                        </form>
                      </div>
                    <% } else { %>
                      <span class="text-success">Selesai</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center text-muted py-4">Belum ada tagihan terbaru.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><h3 class="card-title">Mutasi Keuangan Terbaru</h3></div>
  <div class="card-body table-responsive p-0">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Tanggal</th>
          <th>Tipe</th>
          <th>Keterangan</th>
          <th>Jumlah</th>
        </tr>
      </thead>
      <tbody>
        <% recentFinance.forEach((item) => { %>
          <tr>
            <td><%= helpers.formatDate(item.tanggal) %></td>
            <td><span class="badge badge-<%= item.tipe === 'pemasukan' ? 'success' : 'danger' %>"><%= item.tipe %></span></td>
            <td><%= item.keterangan %></td>
            <td><%= helpers.formatCurrency(item.jumlah) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%
  const financeLabels = analytics.monthlyFinance.map((item) => item.periode);
  const incomeData = analytics.monthlyFinance.map((item) => item.pemasukan);
  const expenseData = analytics.monthlyFinance.map((item) => item.pengeluaran);
  const cubicLabels = analytics.cubicSales.map((item) => `${item.bulan}/${item.tahun}`);
  const cubicData = analytics.cubicSales.map((item) => item.total_kubik);
  const paymentLabels = analytics.paymentStatus.map((item) => item.status_bayar);
  const paymentData = analytics.paymentStatus.map((item) => item.total);
%>

<script id="finance-labels-data" type="application/json"><%- JSON.stringify(financeLabels) %></script>
<script id="income-data" type="application/json"><%- JSON.stringify(incomeData) %></script>
<script id="expense-data" type="application/json"><%- JSON.stringify(expenseData) %></script>
<script id="payment-labels-data" type="application/json"><%- JSON.stringify(paymentLabels) %></script>
<script id="payment-data" type="application/json"><%- JSON.stringify(paymentData) %></script>
<script id="cubic-labels-data" type="application/json"><%- JSON.stringify(cubicLabels) %></script>
<script id="cubic-data" type="application/json"><%- JSON.stringify(cubicData) %></script>
<script src="/vendor/chart.js/dist/chart.umd.js"></script>
<script>
  function parseJsonScript(id) {
    var el = document.getElementById(id);
    if (!el) return [];
    try {
      return JSON.parse(el.textContent || '[]');
    } catch (error) {
      return [];
    }
  }

  var financeLabelsData = parseJsonScript('finance-labels-data');
  var incomeSeries = parseJsonScript('income-data');
  var expenseSeries = parseJsonScript('expense-data');
  var paymentLabelsData = parseJsonScript('payment-labels-data');
  var paymentSeries = parseJsonScript('payment-data');
  var cubicLabelsData = parseJsonScript('cubic-labels-data');
  var cubicSeries = parseJsonScript('cubic-data');

  new Chart(document.getElementById('financeChart'), {
    type: 'bar',
    data: {
      labels: financeLabelsData,
      datasets: [
        { label: 'Pemasukan', backgroundColor: '#0d9488', borderRadius: 6, data: incomeSeries },
        { label: 'Pengeluaran', backgroundColor: '#ef4444', borderRadius: 6, data: expenseSeries }
      ]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { labels: { font: { family: 'Inter' } } }
      }
    }
  });

  new Chart(document.getElementById('paymentChart'), {
    type: 'doughnut',
    data: {
      labels: paymentLabelsData.map(l => l === 'belum_bayar' ? 'Belum Bayar' : 'Lunas'),
      datasets: [{ data: paymentSeries, backgroundColor: ['#f59e0b', '#10b981'], borderConfirm: 0 }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom', labels: { font: { family: 'Inter' } } }
      }
    }
  });

  new Chart(document.getElementById('cubicChart'), {
    type: 'line',
    data: {
      labels: cubicLabelsData,
      datasets: [{ 
        label: 'Kubik Terjual', 
        borderColor: '#2563eb', 
        backgroundColor: 'rgba(37, 99, 235, 0.05)',
        fill: true, 
        tension: 0.3,
        borderWidth: 3,
        pointBackgroundColor: '#2563eb',
        data: cubicSeries 
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { labels: { font: { family: 'Inter' } } }
      }
    }
  });
</script>
<%- include('../partials/admin-footer') %>
