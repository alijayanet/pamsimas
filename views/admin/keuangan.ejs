<%- include('../partials/admin-header', { title, activeMenu }) %>

<div class="row">
  <!-- Form Input Pengeluaran -->
  <div class="col-lg-4">
    <div class="card card-danger card-outline">
      <div class="card-header">
        <h3 class="card-title"><i class="fas fa-minus-circle mr-2"></i>Catat Pengeluaran</h3>
      </div>
      <div class="card-body">
        <form action="/admin/pengeluaran" method="post">
          <input type="hidden" name="redirect_to" value="/admin/keuangan">
          <div class="form-group">
            <label>Tanggal</label>
            <input type="date" name="tanggal" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>" required>
          </div>
          <div class="form-group">
            <label>Jumlah (Rp)</label>
            <div class="input-group">
              <div class="input-group-prepend"><span class="input-group-text">Rp</span></div>
              <input type="number" name="jumlah" id="input-jumlah" class="form-control" min="0" placeholder="0" required>
            </div>
            <small class="text-muted" id="jumlah-preview"></small>
          </div>
          <div class="form-group">
            <label>Keterangan</label>
            <textarea name="keterangan" class="form-control" rows="3" placeholder="Contoh: Biaya operasional pompa, Gaji petugas..." required></textarea>
          </div>
          <button type="submit" class="btn btn-danger btn-block">
            <i class="fas fa-save mr-1"></i> Catat Pengeluaran
          </button>
        </form>
      </div>
    </div>

    <!-- Download CSV -->
    <div class="card card-info card-outline">
      <div class="card-header">
        <h3 class="card-title"><i class="fas fa-file-csv mr-2"></i>Unduh Laporan CSV</h3>
      </div>
      <div class="card-body">
        <form action="/admin/laporan/export-csv" method="get">
          <div class="form-group">
            <label>Jenis Laporan</label>
            <select name="jenis" id="keu-export-jenis" class="form-control">
              <option value="bku">Buku Kas Umum (BKU)</option>
              <option value="rekap_pemakaian">Rekap Pemakaian Pelanggan</option>
              <option value="tunggakan">Daftar Tunggakan</option>
            </select>
          </div>
          <div id="keu-filter-tanggal">
            <div class="form-row">
              <div class="form-group col-6">
                <label>Dari</label>
                <input type="date" name="dari" id="keu-dari" class="form-control form-control-sm">
              </div>
              <div class="form-group col-6">
                <label>Sampai</label>
                <input type="date" name="sampai" id="keu-sampai" class="form-control form-control-sm">
              </div>
            </div>
          </div>
          <div id="keu-filter-periode" style="display:none;">
            <div class="form-row">
              <div class="form-group col-6">
                <label>Bulan</label>
                <select name="bulan" class="form-control form-control-sm">
                  <% for(let m=1; m<=12; m++) { %>
                    <option value="<%= m %>" <%= m === bulan ? 'selected' : '' %>><%= m %></option>
                  <% } %>
                </select>
              </div>
              <div class="form-group col-6">
                <label>Tahun</label>
                <input type="number" name="tahun" class="form-control form-control-sm" value="<%= tahun %>" min="2000" max="3000">
              </div>
            </div>
          </div>
          <button type="submit" class="btn btn-info btn-block">
            <i class="fas fa-download mr-1"></i> Download CSV
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Riwayat Keuangan -->
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center flex-wrap">
        <h3 class="card-title mb-0"><i class="fas fa-history mr-2"></i>Riwayat Keuangan</h3>
        <form action="/admin/keuangan" method="get" class="form-inline mt-1 mt-md-0">
          <input type="date" name="dari" value="<%= dari %>" class="form-control form-control-sm mr-1" placeholder="Dari">
          <input type="date" name="sampai" value="<%= sampai %>" class="form-control form-control-sm mr-1" placeholder="Sampai">
          <button type="submit" class="btn btn-sm btn-outline-secondary mr-1">Filter</button>
          <% if (dari || sampai) { %>
            <a href="/admin/keuangan" class="btn btn-sm btn-outline-danger">Reset</a>
          <% } %>
        </form>
      </div>
      <div class="card-body table-responsive p-0">
        <table class="table table-striped table-hover mb-0">
          <thead>
            <tr>
              <th>Tanggal</th>
              <th>Tipe</th>
              <th>Keterangan</th>
              <th class="text-right">Jumlah</th>
            </tr>
          </thead>
          <tbody>
            <% if (entries.length) { %>
              <% let totalPemasukan = 0; let totalPengeluaran = 0; %>
              <% entries.forEach((item) => { %>
                <% if (item.tipe === 'pemasukan') totalPemasukan += item.jumlah; else totalPengeluaran += item.jumlah; %>
                <tr>
                  <td class="text-nowrap"><%= helpers.formatDate(item.tanggal) %></td>
                  <td>
                    <span class="badge badge-<%= item.tipe === 'pemasukan' ? 'success' : 'danger' %>">
                      <i class="fas fa-<%= item.tipe === 'pemasukan' ? 'plus' : 'minus' %>"></i>
                      <%= item.tipe %>
                    </span>
                  </td>
                  <td><%= item.keterangan %></td>
                  <td class="text-right text-nowrap font-weight-bold text-<%= item.tipe === 'pemasukan' ? 'success' : 'danger' %>">
                    <%= item.tipe === 'pengeluaran' ? '−' : '+' %> <%= helpers.formatCurrency(item.jumlah) %>
                  </td>
                </tr>
              <% }) %>
              <!-- Baris total -->
              <tr class="table-light font-weight-bold">
                <td colspan="3" class="text-right text-muted">Total Pemasukan</td>
                <td class="text-right text-success"><%= helpers.formatCurrency(totalPemasukan) %></td>
              </tr>
              <tr class="table-light font-weight-bold">
                <td colspan="3" class="text-right text-muted">Total Pengeluaran</td>
                <td class="text-right text-danger"><%= helpers.formatCurrency(totalPengeluaran) %></td>
              </tr>
              <tr class="table-<%= (totalPemasukan - totalPengeluaran) >= 0 ? 'success' : 'danger' %> font-weight-bold">
                <td colspan="3" class="text-right">Saldo</td>
                <td class="text-right text-nowrap"><%= helpers.formatCurrency(totalPemasukan - totalPengeluaran) %></td>
              </tr>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center text-muted py-4">
                  <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                  Belum ada riwayat keuangan<% if (dari || sampai) { %> untuk filter yang dipilih<% } %>.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  // Preview jumlah dalam format Rupiah
  const inputJumlah = document.getElementById('input-jumlah');
  const jumlahPreview = document.getElementById('jumlah-preview');
  if (inputJumlah) {
    inputJumlah.addEventListener('input', function () {
      const val = parseInt(this.value, 10);
      if (!isNaN(val) && val > 0) {
        jumlahPreview.textContent = 'Rp ' + val.toLocaleString('id-ID');
      } else {
        jumlahPreview.textContent = '';
      }
    });
  }

  // Toggle filter CSV
  const keuExportJenis = document.getElementById('keu-export-jenis');
  if (keuExportJenis) {
    const now = new Date();
    const d1 = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
    const d2 = new Date(now.getFullYear(), now.getMonth() + 1, 0).toISOString().split('T')[0];
    const dariEl = document.getElementById('keu-dari');
    const sampaiEl = document.getElementById('keu-sampai');
    if (dariEl) dariEl.value = d1;
    if (sampaiEl) sampaiEl.value = d2;

    keuExportJenis.addEventListener('change', function () {
      const isBku = this.value === 'bku';
      document.getElementById('keu-filter-tanggal').style.display = isBku ? '' : 'none';
      document.getElementById('keu-filter-periode').style.display = isBku ? 'none' : '';
    });
  }
</script>

<%- include('../partials/admin-footer') %>
