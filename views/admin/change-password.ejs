<%- include('../partials/admin-header', { title: 'Ubah Password Admin', activeMenu: 'pengaturan' }) %>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card card-primary">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-lock mr-2"></i>Ubah Password Admin
        </h3>
      </div>
      <div class="card-body">
        <form action="/admin/change-password" method="post">
          <div class="form-group">
            <label for="current_password">Password Saat Ini</label>
            <input 
              type="password" 
              id="current_password"
              name="current_password" 
              class="form-control <%= flash?.type === 'danger' && flash?.message?.includes('saat ini') ? 'is-invalid' : '' %>"
              placeholder="Masukkan password saat ini"
              required
            >
            <% if (flash?.type === 'danger' && flash?.message?.includes('saat ini')) { %>
              <div class="invalid-feedback d-block"><%= flash.message %></div>
            <% } %>
          </div>

          <div class="form-group">
            <label for="new_password">Password Baru</label>
            <input 
              type="password" 
              id="new_password"
              name="new_password" 
              class="form-control <%= flash?.type === 'danger' && flash?.message?.includes('Password baru') ? 'is-invalid' : '' %>"
              placeholder="Masukkan password baru (min 6 karakter)"
              minlength="6"
              required
            >
            <small class="form-text text-muted">Minimal 6 karakter. Gunakan kombinasi huruf, angka, dan simbol untuk keamanan lebih baik.</small>
            <% if (flash?.type === 'danger' && flash?.message?.includes('Password baru')) { %>
              <div class="invalid-feedback d-block"><%= flash.message %></div>
            <% } %>
          </div>

          <div class="form-group">
            <label for="confirm_password">Konfirmasi Password</label>
            <input 
              type="password" 
              id="confirm_password"
              name="confirm_password" 
              class="form-control <%= flash?.type === 'danger' && flash?.message?.includes('tidak sama') ? 'is-invalid' : '' %>"
              placeholder="Ulangi password baru"
              minlength="6"
              required
            >
            <% if (flash?.type === 'danger' && flash?.message?.includes('tidak sama')) { %>
              <div class="invalid-feedback d-block"><%= flash.message %></div>
            <% } %>
          </div>

          <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle mr-2"></i>
            <strong>Tips Keamanan:</strong>
            <ul class="mb-0 mt-2">
              <li>Gunakan password yang sulit ditebak</li>
              <li>Jangan gunakan tanggal lahir atau nama</li>
              <li>Ganti password secara berkala</li>
              <li>Jangan bagikan password ke orang lain</li>
            </ul>
          </div>

          <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-save mr-2"></i>Simpan Password Baru
            </button>
            <a href="/admin" class="btn btn-secondary ml-2">
              <i class="fas fa-times mr-2"></i>Batal
            </a>
          </div>
        </form>
      </div>
    </div>

    <div class="card card-warning mt-3">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fas fa-exclamation-triangle mr-2"></i>Informasi Penting
        </h3>
      </div>
      <div class="card-body">
        <p>
          <strong>Password yang kuat membantu melindungi akun Anda.</strong>
        </p>
        <p>Pastikan Anda:</p>
        <ul>
          <li>Menggunakan kombinasi huruf besar, huruf kecil, angka, dan simbol</li>
          <li>Tidak menggunakan informasi pribadi yang mudah ditebak</li>
          <li>Tidak menggunakan password yang sama dengan akun lain</li>
          <li>Mengingat password baru (jangan tulis di tempat yang terlihat)</li>
        </ul>
        <hr>
        <p class="text-muted mb-0">
          <small>
            <i class="fas fa-clock mr-1"></i>
            Perubahan password akan langsung berlaku. Anda harus login kembali dengan password baru.
          </small>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>
