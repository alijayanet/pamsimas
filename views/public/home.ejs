<%- include('../partials/public-header', { title, bodyClass: 'bg-light', containerClass: 'container py-3 py-md-5' }) %>

<div class="card public-hero border-0 shadow-sm mb-3">
  <div class="card-body p-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center">
      <div class="d-flex align-items-center mb-3 mb-md-0">
        <% if (appConfig?.logo_url) { %>
          <img src="<%= appConfig.logo_url %>" alt="Logo" class="public-logo mr-3">
        <% } else { %>
          <div class="public-logo-fallback mr-3"><i class="fas fa-tint"></i></div>
        <% } %>
        <div>
          <div class="h4 mb-1 text-white"><%= appConfig?.nama_aplikasi || 'PAMSIMAS' %></div>
          <div class="public-hero-muted"><%= appConfig?.nama_instansi || 'Unit Pengelola PAMSIMAS' %></div>
        </div>
      </div>
      <div class="d-flex flex-wrap">
        <a href="/pelanggan/cek" class="btn btn-light mr-2 mb-2">Cek Tagihan</a>
        <a href="/pelanggan/login" class="btn btn-primary mr-2 mb-2">Login Pelanggan</a>
        <a href="/login" class="btn btn-outline-light mb-2">Login Petugas</a>
      </div>
    </div>
  </div>
</div>

<% if (currentUser) { %>
  <div class="alert alert-info d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center">
    <div class="mb-2 mb-md-0">
      Anda login sebagai <strong><%= currentUser.nama %></strong> (<%= currentUser.role %>).
    </div>
    <% if (dashboardUrl) { %>
      <a href="<%= dashboardUrl %>" class="btn btn-sm btn-primary">Buka Dashboard</a>
    <% } %>
  </div>
<% } %>

<div class="row">
  <div class="col-lg-7 mb-3">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <div class="h5 mb-1"><%= (appConfig?.public_home_headline || '').trim() || 'Informasi Tarif' %></div>
        <div class="text-muted mb-3"><%= (appConfig?.public_home_tagline || '').trim() || 'Tarif ini diambil langsung dari pengaturan admin (dinamis).' %></div>

        <div class="row">
          <div class="col-sm-6 mb-3">
            <div class="border rounded p-3 h-100">
              <div class="small text-muted mb-1">Harga per m3</div>
              <div class="h5 mb-0"><%= helpers.formatCurrency(pricing?.harga_per_kubik || 0) %> / m3</div>
            </div>
          </div>
          <div class="col-sm-6 mb-3">
            <div class="border rounded p-3 h-100">
              <div class="small text-muted mb-1">Minimum abonemen</div>
              <div class="h5 mb-0"><%= Number(pricing?.minimum_pemakaian_kubik || 0) %> m3</div>
            </div>
          </div>
          <div class="col-sm-6 mb-3">
            <div class="border rounded p-3 h-100">
              <div class="small text-muted mb-1">Biaya admin</div>
              <div class="h5 mb-0"><%= helpers.formatCurrency(pricing?.biaya_admin || 0) %></div>
            </div>
          </div>
          <div class="col-sm-6 mb-3">
            <div class="border rounded p-3 h-100">
              <div class="small text-muted mb-1">Denda keterlambatan</div>
              <div class="h5 mb-0"><%= helpers.formatCurrency(pricing?.denda_keterlambatan || 0) %></div>
            </div>
          </div>
        </div>

        <div class="alert alert-light border mb-0">
          <div class="font-weight-bold mb-1">Catatan</div>
          <div class="text-muted">
            Kubik yang ditagihkan mengikuti aturan abonemen: <strong>kubik ditagih = max(pemakaian asli, minimum abonemen)</strong>.
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-5 mb-3">
    <% if ((appConfig?.public_profile_text || '').trim()) { %>
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-body p-4">
          <div class="h5 mb-2">Profil</div>
          <div class="text-muted" style="white-space: pre-line;"><%= appConfig.public_profile_text %></div>
        </div>
      </div>
    <% } %>

    <div class="card shadow-sm border-0 mb-3">
      <div class="card-body p-4">
        <div class="h5 mb-2">Jadwal & Alur</div>
        <div class="text-muted mb-3">Agar pencatatan dan penagihan rapi per periode.</div>

        <div class="border rounded p-3 mb-3">
          <div class="small text-muted mb-1">Window input meter</div>
          <div class="font-weight-bold">Tanggal <%= collectionWindow.startDay %> – <%= collectionWindow.endDay %></div>
          <div class="small text-muted mt-1">Input pada periode ini akan menjadi tagihan bulan berikutnya.</div>
        </div>

        <div class="border rounded p-3">
          <div class="small text-muted mb-1">Generate tagihan otomatis</div>
          <div class="font-weight-bold">Mulai tanggal <%= autoGenerateDay %> setiap awal bulan</div>
          <div class="small text-muted mt-1">Admin tetap bisa generate manual kapan saja.</div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <div class="h5 mb-2">Kontak Loket</div>
        <div class="text-muted mb-3">Informasi ini diambil dari pengaturan aplikasi.</div>

        <div class="mb-2">
          <div class="small text-muted">Alamat Loket</div>
          <div><%= appConfig?.alamat_loket || '-' %></div>
        </div>
        <div class="mb-3">
          <div class="small text-muted">WhatsApp Loket</div>
          <div><%= appConfig?.no_whatsapp_loket || '-' %></div>
        </div>
        <% if ((appConfig?.public_service_hours_text || '').trim()) { %>
          <div class="mb-3">
            <div class="small text-muted">Jam Layanan</div>
            <div style="white-space: pre-line;"><%= appConfig.public_service_hours_text %></div>
          </div>
        <% } %>
        <% if ((appConfig?.public_payment_info_text || '').trim()) { %>
          <div class="mb-3">
            <div class="small text-muted">Info Pembayaran</div>
            <div style="white-space: pre-line;"><%= appConfig.public_payment_info_text %></div>
          </div>
        <% } %>

        <div class="d-flex flex-wrap">
          <a href="/pelanggan/cek" class="btn btn-primary mr-2 mb-2">Cek Tagihan</a>
          <a href="/pelanggan/login" class="btn btn-outline-primary mr-2 mb-2">Dashboard Pelanggan</a>
          <a href="/kasir" class="btn btn-outline-secondary mb-2">Kasir / Loket</a>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-4">
    <div class="h5 mb-3">Ringkasan Sistem</div>
    <div class="row">
      <div class="col-md-4 mb-3">
        <div class="border rounded p-3 h-100">
          <div class="small text-muted mb-1">Total Pelanggan</div>
          <div class="h4 mb-0"><%= summary?.total_pelanggan || 0 %></div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="border rounded p-3 h-100">
          <div class="small text-muted mb-1">Tagihan Belum Lunas</div>
          <div class="h4 mb-0"><%= summary?.tagihan_belum_lunas || 0 %></div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="border rounded p-3 h-100">
          <div class="small text-muted mb-1">Metode Pembayaran</div>
          <div class="mb-0">Loket & QRIS</div>
        </div>
      </div>
    </div>

    <% if (appConfig?.qris_help_text) { %>
      <div class="alert alert-info mb-0"><%= appConfig.qris_help_text %></div>
    <% } %>
  </div>
</div>

<%- include('../partials/public-footer') %>
