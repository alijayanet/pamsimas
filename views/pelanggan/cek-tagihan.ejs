<%- include('../partials/public-header', { title }) %>

<% const publicSearchResults = typeof searchResults !== 'undefined' && searchResults ? searchResults : []; %>
<%
  var bulanNames = ['','Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
%>

<style>
/* ============================================================
   INVOICE PUBLIK — TAMPILAN LAYAR
   ============================================================ */
.pub-inv-card {
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 4px 28px rgba(0,0,0,.10);
  overflow: hidden;
  border: 1px solid #e0e4ea;
  margin-bottom: 1.5rem;
}

/* Header berwarna */
.pub-inv-header {
  background: linear-gradient(135deg, #0047ab 0%, #1565c0 60%, #0288d1 100%);
  color: #fff;
  padding: 18px 24px 16px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}
.pub-inv-header-left { display: flex; align-items: center; gap: 14px; }
.pub-inv-logo {
  width: 50px; height: 50px; object-fit: contain;
  background: #fff; border-radius: 8px; padding: 4px; flex-shrink: 0;
}
.pub-inv-logo-fallback {
  width: 50px; height: 50px; background: rgba(255,255,255,.18);
  border-radius: 8px; display: flex; align-items: center;
  justify-content: center; font-size: 1.5rem; flex-shrink: 0;
}
.pub-inv-org-name { font-size: .98rem; font-weight: 700; line-height: 1.2; }
.pub-inv-org-sub  { font-size: .76rem; opacity: .85; margin-top: 2px; }
.pub-inv-header-right { text-align: right; flex-shrink: 0; }
.pub-inv-doc-label{ font-size: .66rem; opacity: .75; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 2px; }
.pub-inv-doc-num  { font-size: 1rem; font-weight: 700; letter-spacing: .02em; }
.pub-inv-status-badge {
  display: inline-block; font-size: .63rem; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase;
  padding: 2px 10px; border-radius: 30px; margin-top: 5px;
}
.pub-inv-status-badge.lunas   { background: #22c55e; color: #fff; }
.pub-inv-status-badge.pending { background: #f59e0b; color: #fff; }

/* Body */
.pub-inv-body { padding: 0 24px 20px; }

.pub-inv-customer-row {
  display: flex; justify-content: space-between; gap: 14px;
  padding: 13px 0 11px; border-bottom: 1px solid #e8eaf0; flex-wrap: wrap;
}
.pub-inv-col { flex: 1; min-width: 100px; }

.pub-inv-label {
  font-size: .67rem; color: #8a94a6; text-transform: uppercase;
  letter-spacing: .07em; margin-bottom: 2px; font-weight: 600;
}
.pub-inv-value { font-size: .87rem; color: #1a1f2e; font-weight: 600; line-height: 1.3; }
.pub-inv-value.mono { font-family: 'Courier New', monospace; letter-spacing: .04em; }

.pub-inv-section-title {
  font-size: .67rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: .09em; color: #6b7280; margin: 13px 0 8px;
  padding-bottom: 4px; border-bottom: 1px solid #f0f2f5;
}

/* Bar stand meter */
.pub-inv-meter-bar {
  display: flex; align-items: stretch;
  margin: 8px 0 12px;
  background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden;
}
.pub-inv-meter-cell { flex: 1; padding: 8px 10px; text-align: center; }
.pub-inv-meter-cell + .pub-inv-meter-cell { border-left: 1px solid #e2e8f0; }
.pub-inv-meter-cell-label { font-size: .63rem; color: #8a94a6; text-transform: uppercase; letter-spacing: .07em; font-weight: 600; }
.pub-inv-meter-cell-val { font-size: .97rem; font-weight: 700; font-family: 'Courier New', monospace; color: #1a1f2e; margin-top: 2px; }
.pub-inv-meter-arrow { padding: 0 4px; color: #9ca3af; font-size: .82rem; display: flex; align-items: center; }

/* Tabel biaya */
.pub-inv-table { width: 100%; border-collapse: collapse; font-size: .87rem; }
.pub-inv-table td { padding: 5px 0; vertical-align: top; color: #374151; }
.pub-inv-table td:last-child { text-align: right; font-weight: 500; white-space: nowrap; }
.pub-inv-table .sep-row td { border-top: 1px dashed #d1d5db; padding-top: 8px; }
.pub-inv-table .total-row td { font-weight: 700; font-size: .93rem; color: #0d6efd; padding-top: 6px; }
.pub-inv-table .denda-row td { color: #ef4444; }

/* Kotak total */
.pub-inv-total-box {
  background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 10px;
  padding: 12px 16px; margin-top: 14px;
  display: flex; align-items: center; justify-content: space-between; gap: 8px; flex-wrap: wrap;
}
.pub-inv-total-label { font-size: .76rem; color: #3b82f6; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
.pub-inv-total-amount { font-size: 1.3rem; font-weight: 800; color: #1d4ed8; }

/* Meta row */
.pub-inv-meta-row {
  display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap;
  margin-top: 13px; padding-top: 11px; border-top: 1px solid #e8eaf0;
}
.pub-inv-meta-col { flex: 1; min-width: 90px; }

/* Footer */
.pub-inv-footer-msg {
  text-align: center; padding: 10px 16px 0;
  color: #9ca3af; font-size: .73rem; line-height: 1.5;
  border-top: 1px dashed #d1d5db; margin-top: 13px;
}

.inv-method-badge {
  display: inline-block; padding: 2px 8px; border-radius: 30px;
  font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
}
.inv-method-badge.tunai    { background: #dcfce7; color: #15803d; }
.inv-method-badge.transfer { background: #dbeafe; color: #1d4ed8; }
.inv-method-badge.qris     { background: #ede9fe; color: #7c3aed; }

/* ============================================================
   PRINT STYLES
   ============================================================ */
@media print {
  /* Sembunyikan semua elemen layar */
  .no-print,
  nav, .navbar, .pelanggan-bottom-nav,
  header, footer, .public-footer,
  .lookup-card,
  .pub-inv-action-bar,
  .pub-inv-history-section,
  .alert,
  .btn {
    display: none !important;
  }

  /* Sembunyikan SEMUA gambar/foto meteran */
  img.meter-photo-thumb,
  img.foto-bukti-img,
  .foto-meter-wrap,
  .meter-photo-link,
  .meter-photo-link img,
  .meter-photo-caption,
  .col-foto-meter {
    display: none !important;
  }

  /* Kolom "Foto Meter" di tabel riwayat: sembunyikan */
  th.th-foto-meter,
  td.td-foto-meter {
    display: none !important;
  }

  body { background: #fff !important; margin: 0 !important; padding: 0 !important; }

  .pub-inv-card {
    border: none !important; box-shadow: none !important; border-radius: 0 !important;
  }
  .pub-inv-header {
    -webkit-print-color-adjust: exact; print-color-adjust: exact;
    padding: 10px 14px !important;
  }
  .pub-inv-body { padding: 0 14px 12px !important; }
  .pub-inv-logo { width: 38px !important; height: 38px !important; }
  .pub-inv-table { font-size: .8rem !important; }
  .pub-inv-table td { padding: 3px 0 !important; }
  .pub-inv-total-box { -webkit-print-color-adjust: exact; print-color-adjust: exact; padding: 8px 12px !important; }
  .pub-inv-total-amount { font-size: 1.05rem !important; }
  .pub-inv-card { page-break-inside: avoid; }
  a { color: #000 !important; text-decoration: none !important; }

  /* Riwayat tidak dicetak (terlalu panjang) */
  .pub-inv-history-section { display: none !important; }
}
</style>

<div class="row justify-content-center">
  <div class="col-lg-9">

    <%# ===== KOTAK PENCARIAN (hanya layar) ===== %>
    <div class="card lookup-card border-0 shadow-sm mb-4 no-print">
      <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap mb-3">
          <div class="d-flex align-items-start">
            <% if (appConfig?.logo_url) { %>
              <img src="<%= appConfig.logo_url %>" alt="Logo" class="public-logo mr-3">
            <% } %>
            <div>
              <h3 class="mb-1">Cek Tagihan <%= appConfig?.nama_aplikasi || 'PAMSIMAS' %></h3>
              <div class="text-muted">Akses cepat tanpa login atau masuk ke dashboard pelanggan.</div>
            </div>
          </div>
          <a href="/pelanggan/login" class="btn btn-outline-primary mt-3 mt-md-0">Login Pelanggan</a>
        </div>
        <form action="/pelanggan/cek" method="get">
          <div class="input-group input-group-lg">
            <input type="text" name="keyword" class="form-control" placeholder="Masukkan No Meter / Nama / No WhatsApp" value="<%= keyword %>" required>
            <div class="input-group-append">
              <button class="btn btn-primary" type="submit">Cek</button>
            </div>
          </div>
        </form>
        <div class="text-muted small mt-2">Untuk privasi, hasil pencarian berdasarkan nama akan menampilkan data sebagian.</div>
      </div>
    </div>

    <%# ===== HASIL PENCARIAN (pilih pelanggan) ===== %>
    <% if (keyword && !pelanggan) { %>
      <% if (publicSearchResults.length) { %>
        <div class="card lookup-card border-0 shadow-sm mb-4 no-print">
          <div class="card-body p-4">
            <div class="h5 mb-2">Pilih Pelanggan</div>
            <div class="text-muted mb-3">Ditemukan beberapa pelanggan. Klik untuk melihat tagihan.</div>
            <div class="list-group">
              <% publicSearchResults.forEach((item) => { %>
                <a href="/pelanggan/cek?keyword=<%= encodeURIComponent(item.no_meteran) %>" class="list-group-item list-group-item-action">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <div class="font-weight-bold"><%= item.nama %></div>
                      <div class="text-muted small">
                        <%= helpers.maskMeter(item.no_meteran) %>
                        &bull; <%= helpers.truncate(item.alamat, 48) %>
                      </div>
                    </div>
                    <span class="badge badge-primary">Cek</span>
                  </div>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-warning">Data pelanggan atau tagihan belum ditemukan.</div>
      <% } %>
    <% } %>

    <%# ============================================================ %>
    <%# ===== ADA TAGIHAN AKTIF ===== %>
    <%# ============================================================ %>
    <% if (pelanggan && latestBill) {
         var metodeBayar = (latestBill.metode_bayar || '').toLowerCase();
    %>

      <%# Bar aksi (hanya layar) %>
      <div class="pub-inv-action-bar no-print d-flex justify-content-between align-items-center mb-3" style="flex-wrap:wrap; gap:8px;">
        <div style="font-size:.85rem; color:#6b7280;">
          <i class="fas fa-file-invoice mr-1"></i> Invoice Tagihan Air
        </div>
        <div class="d-flex" style="gap:8px; flex-wrap:wrap;">
          <% if (qrisEnabled && latestBill.status_bayar !== 'lunas') { %>
            <a href="/pelanggan/tagihan/<%= latestBill.id %>/qris?access_key=<%= encodeURIComponent(accessKey || '') %>"
               class="btn btn-sm btn-success">
              <i class="fas fa-qrcode mr-1"></i> Bayar QRIS
            </a>
          <% } %>
          <button onclick="window.print()" class="btn btn-sm btn-outline-primary">
            <i class="fas fa-print mr-1"></i> Cetak Invoice
          </button>
        </div>
      </div>

      <%# ===== INVOICE CARD ===== %>
      <div class="pub-inv-card">

        <%# ── HEADER BERWARNA ── %>
        <div class="pub-inv-header">
          <div class="pub-inv-header-left">
            <% if (appConfig?.logo_url) { %>
              <img src="<%= appConfig.logo_url %>" alt="Logo" class="pub-inv-logo">
            <% } else { %>
              <div class="pub-inv-logo-fallback"><i class="fas fa-tint"></i></div>
            <% } %>
            <div>
              <div class="pub-inv-org-name"><%= appConfig?.nama_aplikasi || 'PAMSIMAS' %></div>
              <div class="pub-inv-org-sub"><%= appConfig?.nama_instansi || 'Unit Pengelola PAMSIMAS' %></div>
              <% if (appConfig?.alamat_loket) { %>
                <div class="pub-inv-org-sub"><%= appConfig.alamat_loket %></div>
              <% } %>
            </div>
          </div>
          <div class="pub-inv-header-right">
            <div class="pub-inv-doc-label">Tagihan Air</div>
            <div class="pub-inv-doc-num">INV-<%= String(latestBill.id).padStart(6, '0') %></div>
            <div class="pub-inv-status-badge <%= latestBill.status_bayar === 'lunas' ? 'lunas' : 'pending' %>">
              <%= latestBill.status_bayar === 'lunas' ? '✓ LUNAS' : '● BELUM BAYAR' %>
            </div>
          </div>
        </div>

        <%# ── BODY ── %>
        <div class="pub-inv-body">

          <%# Info Pelanggan %>
          <div class="pub-inv-customer-row">
            <div class="pub-inv-col">
              <div class="pub-inv-label">Pelanggan</div>
              <div class="pub-inv-value"><%= pelanggan.nama %></div>
            </div>
            <div class="pub-inv-col">
              <div class="pub-inv-label">No. Meter</div>
              <div class="pub-inv-value mono"><%= pelanggan.no_meteran %></div>
            </div>
            <div class="pub-inv-col" style="flex:2;">
              <div class="pub-inv-label">Alamat</div>
              <div class="pub-inv-value"><%= pelanggan.alamat || '-' %></div>
            </div>
            <div class="pub-inv-col">
              <div class="pub-inv-label">Periode</div>
              <%
                var bln = parseInt(latestBill.bulan, 10);
                var blnLabel = (bln >= 1 && bln <= 12) ? bulanNames[bln] : latestBill.bulan;
              %>
              <div class="pub-inv-value"><%= blnLabel %> <%= latestBill.tahun %></div>
            </div>
          </div>

          <%# Bar Stand Meter %>
          <div class="pub-inv-section-title">Rincian Pemakaian Air</div>
          <div class="pub-inv-meter-bar">
            <div class="pub-inv-meter-cell">
              <div class="pub-inv-meter-cell-label">Stand Awal</div>
              <div class="pub-inv-meter-cell-val"><%= latestBill.meteran_awal ?? '-' %></div>
            </div>
            <div class="pub-inv-meter-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="pub-inv-meter-cell">
              <div class="pub-inv-meter-cell-label">Stand Akhir</div>
              <div class="pub-inv-meter-cell-val"><%= latestBill.meteran_akhir ?? '-' %></div>
            </div>
            <div class="pub-inv-meter-arrow"><i class="fas fa-equals"></i></div>
            <div class="pub-inv-meter-cell">
              <div class="pub-inv-meter-cell-label">Pemakaian</div>
              <div class="pub-inv-meter-cell-val"><%= latestBill.total_kubik %> m³</div>
            </div>
            <div class="pub-inv-meter-cell">
              <div class="pub-inv-meter-cell-label">Ditagihkan</div>
              <div class="pub-inv-meter-cell-val"><%= breakdown.kubikDitagihkan %> m³</div>
            </div>
          </div>

          <%# Foto meteran — HANYA LAYAR, tidak dicetak %>
          <% if (latestBill.foto_bukti) { %>
            <div class="foto-meter-wrap no-print mb-3">
              <div class="pub-inv-label mb-1">Foto Meter</div>
              <a href="<%= latestBill.foto_bukti %>" class="meter-photo-link" data-meter-preview
                 data-title="Foto meter <%= latestBill.bulan %>/<%= latestBill.tahun %>">
                <img src="<%= latestBill.foto_bukti %>" alt="Foto meteran"
                     class="img-fluid rounded border foto-bukti-img" style="max-height:180px; object-fit:cover;">
              </a>
            </div>
          <% } %>

          <%# Rincian Biaya %>
          <div class="pub-inv-section-title">Rincian Biaya</div>
          <table class="pub-inv-table">
            <% if (breakdown.minimumPemakaianKubik > 0) { %>
            <tr>
              <td>Minimum abonemen</td>
              <td><%= breakdown.minimumPemakaianKubik %> m³</td>
            </tr>
            <% } %>
            <tr>
              <td>Pemakaian ditagihkan</td>
              <td><%= breakdown.kubikDitagihkan %> m³</td>
            </tr>
            <% if (breakdown.hargaPerKubik > 0) { %>
            <tr>
              <td>Tarif per m³</td>
              <td><%= helpers.formatCurrency(breakdown.hargaPerKubik) %></td>
            </tr>
            <tr>
              <td>Biaya pemakaian air</td>
              <td><%= helpers.formatCurrency(breakdown.biayaAir) %></td>
            </tr>
            <% } %>
            <% if (breakdown.biayaAdmin > 0) { %>
            <tr>
              <td>Biaya administrasi</td>
              <td><%= helpers.formatCurrency(breakdown.biayaAdmin) %></td>
            </tr>
            <% } %>
            <% if (breakdown.denda > 0) { %>
            <tr class="denda-row">
              <td>Denda keterlambatan</td>
              <td><%= helpers.formatCurrency(breakdown.denda) %></td>
            </tr>
            <% } %>
            <tr class="sep-row"><td></td><td></td></tr>
            <tr class="total-row">
              <td>Total Tagihan</td>
              <td><%= helpers.formatCurrency(latestBill.total_tagihan) %></td>
            </tr>
          </table>

          <%# Kotak Total %>
          <div class="pub-inv-total-box">
            <div>
              <div class="pub-inv-total-label">Total Tagihan</div>
              <% if (latestBill.status_bayar === 'lunas') { %>
                <div style="font-size:.73rem; color:#16a34a; margin-top:2px;">
                  ✓ Dibayar
                  <% if (breakdown.tanggalBayar) { %><%= helpers.formatDate(breakdown.tanggalBayar) %><% } %>
                  <% if (breakdown.metodeBayar) { %>
                    &nbsp;<span class="inv-method-badge <%= (breakdown.metodeBayar||'').toLowerCase() %>"><%= breakdown.metodeBayar %></span>
                  <% } %>
                </div>
              <% } else { %>
                <div style="font-size:.73rem; color:#d97706; margin-top:2px;">Belum dibayar</div>
              <% } %>
            </div>
            <div class="pub-inv-total-amount"><%= helpers.formatCurrency(latestBill.total_tagihan) %></div>
          </div>

          <%# Meta (abonemen info) %>
          <% if (breakdown.abonemenApplied) { %>
            <div class="alert alert-info mt-3 mb-0 no-print" style="font-size:.82rem;">
              Pemakaian asli <strong><%= latestBill.total_kubik %> m³</strong>, namun ditagih minimum abonemen <strong><%= breakdown.kubikDitagihkan %> m³</strong>.
            </div>
          <% } %>

          <%# Footer pesan %>
          <div class="pub-inv-footer-msg">
            <% if (appConfig?.no_whatsapp_loket) { %>
              <div>Pertanyaan? Hubungi: <strong><%= appConfig.no_whatsapp_loket %></strong></div>
            <% } %>
            <% if (appConfig?.footer_kwitansi) { %>
              <div><%= appConfig.footer_kwitansi %></div>
            <% } %>
            <div style="margin-top:3px;">Dokumen ini merupakan tagihan resmi &bull; <%= appConfig?.nama_aplikasi || 'PAMSIMAS' %></div>
          </div>

        </div><%# end pub-inv-body %>
      </div><%# end pub-inv-card %>

      <%# ===== RIWAYAT (hanya layar, tidak dicetak) ===== %>
      <div class="pub-inv-history-section no-print">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <h5 class="mb-3">Riwayat 6 Bulan Terakhir</h5>
            <div class="table-responsive">
              <table class="table table-striped mb-0" style="font-size:.88rem;">
                <thead>
                  <tr>
                    <th>Periode</th>
                    <th>Pemakaian</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th class="th-foto-meter">Foto Meter</th>
                    <th>Tgl Bayar</th>
                  </tr>
                </thead>
                <tbody>
                  <% history.forEach((item) => { %>
                    <tr>
                      <td><%= item.bulan %>/<%= item.tahun %></td>
                      <td><%= item.total_kubik %> m³</td>
                      <td><%= helpers.formatCurrency(item.total_tagihan) %></td>
                      <td>
                        <span class="badge badge-<%= item.status_bayar === 'lunas' ? 'success' : 'warning' %>">
                          <%= item.status_bayar %>
                        </span>
                      </td>
                      <td class="td-foto-meter">
                        <% if (item.foto_bukti) { %>
                          <a href="<%= item.foto_bukti %>" class="meter-photo-link"
                             data-meter-preview data-title="Foto meter <%= item.bulan %>/<%= item.tahun %>">
                            <img src="<%= item.foto_bukti %>" alt="Foto meter"
                                 class="meter-photo-thumb small foto-bukti-img">
                          </a>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                      <td><%= item.tgl_bayar ? helpers.formatDate(item.tgl_bayar) : '-' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    <%# ============================================================ %>
    <%# ===== ADA BACAAN METER TAPI BELUM ADA TAGIHAN ===== %>
    <%# ============================================================ %>
    <% } else if (pelanggan && latestReading) { %>

      <div class="pub-inv-card">
        <div class="pub-inv-header">
          <div class="pub-inv-header-left">
            <% if (appConfig?.logo_url) { %>
              <img src="<%= appConfig.logo_url %>" alt="Logo" class="pub-inv-logo">
            <% } else { %>
              <div class="pub-inv-logo-fallback"><i class="fas fa-tint"></i></div>
            <% } %>
            <div>
              <div class="pub-inv-org-name"><%= appConfig?.nama_aplikasi || 'PAMSIMAS' %></div>
              <div class="pub-inv-org-sub"><%= appConfig?.nama_instansi || 'Unit Pengelola PAMSIMAS' %></div>
            </div>
          </div>
          <div class="pub-inv-header-right">
            <div class="pub-inv-doc-label">Informasi Meter</div>
            <div class="pub-inv-doc-num"><%= pelanggan.no_meteran %></div>
            <div class="pub-inv-status-badge pending">Tagihan Belum Terbit</div>
          </div>
        </div>

        <div class="pub-inv-body">

          <div class="pub-inv-customer-row">
            <div class="pub-inv-col">
              <div class="pub-inv-label">Pelanggan</div>
              <div class="pub-inv-value"><%= pelanggan.nama %></div>
            </div>
            <div class="pub-inv-col">
              <div class="pub-inv-label">No. Meter</div>
              <div class="pub-inv-value mono"><%= pelanggan.no_meteran %></div>
            </div>
            <div class="pub-inv-col" style="flex:2;">
              <div class="pub-inv-label">Alamat</div>
              <div class="pub-inv-value"><%= pelanggan.alamat || '-' %></div>
            </div>
          </div>

          <div class="alert alert-warning mt-3" style="font-size:.85rem; border-radius:8px;">
            <i class="fas fa-info-circle mr-1"></i>
            Data pencatatan meter ditemukan, namun tagihan periode ini belum terbit.
            Admin akan melakukan generate tagihan otomatis atau manual.
          </div>

          <div class="pub-inv-section-title">Catatan Meter Terakhir</div>
          <div class="pub-inv-meter-bar">
            <div class="pub-inv-meter-cell">
              <div class="pub-inv-meter-cell-label">Stand Awal</div>
              <div class="pub-inv-meter-cell-val"><%= latestReading.meteran_awal ?? '-' %></div>
            </div>
            <div class="pub-inv-meter-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="pub-inv-meter-cell">
              <div class="pub-inv-meter-cell-label">Stand Akhir</div>
              <div class="pub-inv-meter-cell-val"><%= latestReading.meteran_akhir ?? '-' %></div>
            </div>
            <div class="pub-inv-meter-arrow"><i class="fas fa-equals"></i></div>
            <div class="pub-inv-meter-cell">
              <div class="pub-inv-meter-cell-label">Pemakaian</div>
              <div class="pub-inv-meter-cell-val"><%= latestReading.total_kubik %> m³</div>
            </div>
          </div>

          <%# Foto meter — HANYA LAYAR %>
          <% if (latestReading.foto_bukti) { %>
            <div class="foto-meter-wrap no-print mb-3">
              <div class="pub-inv-label mb-1">Foto Meter Periode <%= latestReading.bulan %>/<%= latestReading.tahun %></div>
              <a href="<%= latestReading.foto_bukti %>" class="meter-photo-link"
                 data-meter-preview data-title="Foto meter <%= latestReading.bulan %>/<%= latestReading.tahun %>">
                <img src="<%= latestReading.foto_bukti %>" alt="Foto meter"
                     class="meter-photo-thumb foto-bukti-img">
              </a>
              <div class="meter-photo-caption">Foto meter periode <%= helpers.monthName(latestReading.bulan) %> <%= latestReading.tahun %>.</div>
            </div>
          <% } %>

          <% if (estimateBreakdown) { %>
            <div class="pub-inv-section-title">Estimasi Tagihan</div>
            <table class="pub-inv-table">
              <% if (estimateBreakdown.minimumPemakaianKubik > 0) { %>
              <tr><td>Minimum abonemen</td><td><%= estimateBreakdown.minimumPemakaianKubik %> m³</td></tr>
              <% } %>
              <tr><td>Pemakaian ditagihkan</td><td><%= estimateBreakdown.kubikDitagihkan %> m³</td></tr>
              <tr><td>Tarif per m³</td><td><%= helpers.formatCurrency(estimateBreakdown.hargaPerKubik) %></td></tr>
              <tr><td>Biaya air</td><td><%= helpers.formatCurrency(estimateBreakdown.biayaAir) %></td></tr>
              <% if (estimateBreakdown.biayaAdmin > 0) { %>
              <tr><td>Biaya administrasi</td><td><%= helpers.formatCurrency(estimateBreakdown.biayaAdmin) %></td></tr>
              <% } %>
              <tr class="sep-row"><td></td><td></td></tr>
              <tr class="total-row"><td>Estimasi Total</td><td><%= helpers.formatCurrency(estimateBreakdown.totalTagihan) %></td></tr>
            </table>

            <div class="pub-inv-total-box" style="margin-top:12px;">
              <div>
                <div class="pub-inv-total-label">Estimasi Tagihan</div>
                <div style="font-size:.73rem; color:#d97706; margin-top:2px;">*Belum resmi, tagihan menyusul</div>
              </div>
              <div class="pub-inv-total-amount"><%= helpers.formatCurrency(estimateBreakdown.totalTagihan) %></div>
            </div>
          <% } %>

          <div class="pub-inv-footer-msg">
            <% if (appConfig?.no_whatsapp_loket) { %>
              <div>Pertanyaan? Hubungi: <strong><%= appConfig.no_whatsapp_loket %></strong></div>
            <% } %>
            <div style="margin-top:3px;"><%= appConfig?.nama_aplikasi || 'PAMSIMAS' %></div>
          </div>

        </div><%# end pub-inv-body %>
      </div><%# end pub-inv-card %>

    <% } %>

  </div>
</div>

<%- include('../partials/public-footer') %>
